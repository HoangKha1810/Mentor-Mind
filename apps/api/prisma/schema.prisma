generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PackageLevel {
  BEGINNER
  FOUNDATION
  INTERMEDIATE
  ADVANCED
  JOB_READY
}

enum PackageCategory {
  FRONTEND
  BACKEND
  FULLSTACK
  AI_ML
  DATA
  MOBILE
  CAREER
  ENGLISH_INTERVIEW
  OTHER
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConsultationStatus {
  REQUESTED
  CONTACTED
  SCHEDULED
  APPROVED
  REJECTED
}

enum RoadmapStatus {
  DRAFT_AI
  PENDING_ADMIN_REVIEW
  NEEDS_STUDENT_INFO
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
}

enum RoadmapItemType {
  TOPIC
  PRACTICE
  PROJECT
  INTERVIEW
  RESOURCE
  HOMEWORK
}

enum RoadmapItemStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum HomeworkStatus {
  ASSIGNED
  SUBMITTED
  REVIEWED
  LATE
}

enum InterviewCategory {
  FRONTEND
  BACKEND
  FULLSTACK
  AI_ML
  DATA
  SQL
  SYSTEM_DESIGN
  BEHAVIORAL
  HR
  PROJECT_DEFENSE
  ENGLISH_INTERVIEW
}

enum InterviewMode {
  TECHNICAL
  BEHAVIORAL
  HR
  PROJECT_DEFENSE
  ENGLISH
  MIXED
}

enum InterviewSessionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CodeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum CodeProblemStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CodeLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  JAVA
  CPP
}

enum CodeVerdict {
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  INTERNAL_ERROR
}

enum ResourceType {
  BOOK
  DOCUMENTATION
  ARTICLE
  VIDEO
  COURSE_PACKAGE
  CODING_PROBLEM
  PROJECT_IDEA
}

enum ResourceDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  JOB_READY
}

enum ResourceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AIUsageStatus {
  SUCCESS
  FAILED
  FALLBACK
  BLOCKED
}

enum AIConversationType {
  GENERAL
  ROADMAP
  PACKAGE
  CODING_PROBLEM
  INTERVIEW
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum NotificationType {
  ROADMAP_APPROVED
  CONSULTATION_SCHEDULED
  BOOKING_CONFIRMED
  HOMEWORK_ASSIGNED
  HOMEWORK_REVIEWED
  AI_REPORT_READY
  PAYMENT_STATUS
  ADMIN_MESSAGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  passwordHash     String
  fullName         String
  avatarUrl        String?
  role             Role          @default(STUDENT)
  status           AccountStatus @default(ACTIVE)
  refreshTokenHash String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastLoginAt      DateTime?

  studentProfile StudentProfile?
  mentorProfile  MentorProfile?
  adminProfile   AdminProfile?
  adminLoginChallenges AdminLoginChallenge[]
}

model AdminLoginChallenge {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model StudentProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  targetRole        String?
  currentLevel      String?
  goals             String?
  weeklyHours       Int?
  learningStyle     String?
  budgetRange       String?
  expectedSalary    String?
  preferredLocation String?
  timezone          String  @default("Asia/Ho_Chi_Minh")
  bio               String?
  personalContext   Json?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MentorProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  headline        String
  bio             String
  skills          Json
  categories      Json
  hourlyRate      Decimal @db.Decimal(10, 2)
  yearsExperience Int
  rating          Float   @default(5)
  isAvailable     Boolean @default(true)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  department String
  notes      String?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutoringPackage {
  id                     String          @id @default(cuid())
  title                  String
  slug                   String          @unique
  shortDescription       String
  longDescription        String
  targetAudience         String
  targetRole             String
  level                  PackageLevel
  category               PackageCategory
  durationWeeks          Int
  recommendedSessions    Int
  sessionDurationMinutes Int
  outcomes               Json
  skills                 Json
  includedAiTools        Json
  mentorType             String
  price                  Decimal         @db.Decimal(10, 2)
  currency               String          @default("USD")
  status                 PackageStatus   @default(DRAFT)
  featured               Boolean         @default(false)
  heroConfig             Json
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  consultationRequests PackageConsultationRequest[]
}

model PackageConsultationRequest {
  id        String             @id @default(cuid())
  studentId String
  packageId String
  message   String
  status    ConsultationStatus @default(REQUESTED)
  adminId   String?
  mentorId  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  package TutoringPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model RoadmapRequest {
  id                    String        @id @default(cuid())
  studentId             String
  goal                  String
  targetRole            String
  currentLevel          String
  currentSkills         Json
  weakAreas             Json
  deadline              DateTime?
  weeklyHours           Int
  preferredSchedule     String
  budgetRange           String
  learningStyle         String
  mentorPreference      String?
  wantsOneOnOneTutoring Boolean       @default(true)
  wantsInterviewPrep    Boolean       @default(false)
  wantsCodePractice     Boolean       @default(false)
  uploadedCvAssetId     String?
  uploadedJdAssetId     String?
  status                RoadmapStatus @default(PENDING_ADMIN_REVIEW)
  aiDraftRoadmapId      String?
  finalRoadmapId        String?
  assignedAdminId       String?
  assignedMentorId      String?
  adminNotes            String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Roadmap {
  id                   String        @id @default(cuid())
  studentId            String
  requestId            String?
  title                String
  summary              String
  targetOutcome        String
  durationWeeks        Int
  level                String
  status               RoadmapStatus @default(DRAFT_AI)
  aiGenerated          Boolean       @default(false)
  adminApproved        Boolean       @default(false)
  mentorId             String?
  adminId              String?
  risks                Json
  recommendedResources Json
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  weeks RoadmapWeek[]
  items RoadmapItem[]
}

model RoadmapWeek {
  id                      String @id @default(cuid())
  roadmapId               String
  weekNumber              Int
  title                   String
  objectives              Json
  topics                  Json
  practiceTasks           Json
  projectTasks            Json
  interviewTasks          Json
  recommendedSessionCount Int

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model RoadmapItem {
  id          String            @id @default(cuid())
  roadmapId   String
  weekId      String?
  type        RoadmapItemType
  title       String
  description String
  status      RoadmapItemStatus @default(TODO)
  dueDate     DateTime?
  order       Int

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

model MentorAvailability {
  id        String  @id @default(cuid())
  mentorId  String
  dayOfWeek Int
  startTime String
  endTime   String
  timezone  String  @default("Asia/Ho_Chi_Minh")
  isActive  Boolean @default(true)
}

model Booking {
  id          String        @id @default(cuid())
  studentId   String
  mentorId    String
  roadmapId   String?
  packageId   String?
  startTime   DateTime
  endTime     DateTime
  timezone    String        @default("Asia/Ho_Chi_Minh")
  status      BookingStatus @default(REQUESTED)
  meetingUrl  String?
  studentNote String?
  mentorNote  String?
  adminNote   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SessionNote {
  id          String   @id @default(cuid())
  bookingId   String
  mentorId    String
  studentId   String
  summary     String
  strengths   Json
  weaknesses  Json
  nextSteps   Json
  privateNote String?
  createdAt   DateTime @default(now())
}

model Homework {
  id          String         @id @default(cuid())
  bookingId   String?
  roadmapId   String?
  mentorId    String
  studentId   String
  title       String
  description String
  dueDate     DateTime
  status      HomeworkStatus @default(ASSIGNED)
  createdAt   DateTime       @default(now())

  submissions HomeworkSubmission[]
}

model HomeworkSubmission {
  id             String         @id @default(cuid())
  homeworkId     String
  studentId      String
  content        String
  assetId        String?
  status         HomeworkStatus @default(SUBMITTED)
  mentorFeedback String?
  score          Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
}

model InterviewQuestion {
  id             String            @id @default(cuid())
  role           String
  category       InterviewCategory
  level          String
  question       String
  expectedPoints Json
  sampleAnswer   String
  commonMistakes Json
  tags           Json
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
}

model InterviewSession {
  id              String                 @id @default(cuid())
  studentId       String
  targetRole      String
  level           String
  mode            InterviewMode
  sourceJdAssetId String?
  status          InterviewSessionStatus @default(IN_PROGRESS)
  overallScore    Int?
  feedback        Json?
  createdAt       DateTime               @default(now())
  completedAt     DateTime?

  answers InterviewAnswer[]
}

model InterviewAnswer {
  id           String   @id @default(cuid())
  sessionId    String
  question     String
  answer       String
  score        Int
  feedback     Json
  betterAnswer String
  createdAt    DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model CodeProblem {
  id                  String            @id @default(cuid())
  title               String
  slug                String            @unique
  difficulty          CodeDifficulty
  category            String
  tags                Json
  statement           String
  inputFormat         String
  outputFormat        String
  constraintsText     String
  examples            Json
  starterCode         Json
  solutionExplanation String
  timeLimitMs         Int
  memoryLimitMb       Int
  isPremium           Boolean           @default(false)
  unlockPrice         Decimal           @default(0) @db.Decimal(10, 2)
  status              CodeProblemStatus @default(DRAFT)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  testCases   CodeTestCase[]
  submissions CodeSubmission[]
  hints       CodeHintUsage[]
}

model CodeTestCase {
  id             String  @id @default(cuid())
  problemId      String
  input          String
  expectedOutput String
  isHidden       Boolean @default(false)
  order          Int

  problem CodeProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model CodeSubmission {
  id           String       @id @default(cuid())
  problemId    String
  studentId    String
  language     CodeLanguage
  code         String
  verdict      CodeVerdict
  runtimeMs    Int?
  memoryKb     Int?
  passedTests  Int
  totalTests   Int
  errorMessage String?
  aiReview     Json?
  createdAt    DateTime     @default(now())

  problem CodeProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model CodeHintUsage {
  id        String   @id @default(cuid())
  problemId String
  studentId String
  hintLevel Int
  hintText  String
  createdAt DateTime @default(now())

  problem CodeProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Resource {
  id               String             @id @default(cuid())
  title            String
  source           String
  author           String?
  type             ResourceType
  url              String?
  description      String
  difficulty       ResourceDifficulty
  category         String
  tags             Json
  estimatedMinutes Int
  whyRecommended   String
  isCurated        Boolean            @default(true)
  status           ResourceStatus     @default(PUBLISHED)
  createdAt        DateTime           @default(now())

  embeddings ResourceEmbedding[]
}

model ResourceEmbedding {
  id         String                 @id @default(cuid())
  resourceId String
  content    String
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model ContentEmbedding {
  id         String                 @id @default(cuid())
  entityType String
  entityId   String
  content    String
  embedding  Unsupported("vector")?
  metadata   Json
  createdAt  DateTime               @default(now())
}

model ResourceSearchLog {
  id        String   @id @default(cuid())
  studentId String
  query     String
  results   Json
  createdAt DateTime @default(now())
}

model CvReview {
  id           String   @id @default(cuid())
  studentId    String
  cvAssetId    String?
  jdAssetId    String?
  cvText       String?
  portfolioUrl String?
  githubUrl    String?
  overallScore Int
  result       Json
  createdAt    DateTime @default(now())
}

model AIConversation {
  id        String             @id @default(cuid())
  userId    String
  type      AIConversationType @default(GENERAL)
  title     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  messages AIMessage[]
}

model AIMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AIMessageRole
  content        String
  metadata       Json
  createdAt      DateTime      @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  template    String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIUsageLog {
  id               String        @id @default(cuid())
  userId           String?
  feature          String
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  estimatedCost    Decimal       @db.Decimal(12, 6)
  status           AIUsageStatus
  errorMessage     String?
  latencyMs        Int
  createdAt        DateTime      @default(now())
}

model AISetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  metadata  Json
  createdAt DateTime         @default(now())
}

model Payment {
  id          String        @id @default(cuid())
  studentId   String
  packageId   String?
  roadmapId   String?
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  provider    String
  providerRef String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(MEDIUM)
  adminId   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model FileAsset {
  id         String   @id @default(cuid())
  ownerId    String
  filename   String
  mimeType   String
  size       Int
  storageKey String
  url        String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json
  createdAt  DateTime @default(now())
}
